# Backend env preset for running directly on your host (outside Docker)

# App + auth
DATABASE_URL=file:./switchyard.db
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=1h
ADMIN_EMAIL=admin@switchyard.dev
ADMIN_NAME=Switchyard Admin
ADMIN_PASSWORD=Switchyard!123

# Router/Caddy (host-local)
ROUTER_DOMAIN=switchyard.localhost
ROUTER_CONSOLE_SUBDOMAIN=console
CONSOLE_TARGET_ORIGIN=http://host.docker.internal:4200
CADDY_ADMIN_URL=http://localhost:2019
# Optional: set both to enable custom TLS cert/key in generated Caddy routes
CADDY_TLS_CERT_FILE=
CADDY_TLS_KEY_FILE=
ROUTER_TARGET_HOST=http://localhost

# Docker orchestration
DOCKER_AUTOSTART=true
DOCKER_NETWORK=switchyard-net

# Health checks
HEALTH_CHECK_INTERVAL_MS=30000
HEALTH_USE_CONTAINER_TARGETS=false

# Host port allocation for slot-a/slot-b
PORT_RANGE_START=4100
PORT_RANGE_END=4700

# Optional Prisma shadow DB for migrate dev
# SHADOW_DATABASE_URL=file:./shadow.db
